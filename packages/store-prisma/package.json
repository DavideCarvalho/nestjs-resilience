{
  "name": "@dudousxd/nestjs-resilience-store-prisma",
  "version": "0.2.0",
  "description": "Prisma (Postgres) ResilienceStore for @dudousxd/nestjs-resilience",
  "license": "MIT",
  "author": "Davide Carvalho",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prisma"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --exclude '**/*.db.spec.ts' --passWithNoTests",
    "test:db": "vitest run",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-resilience": ">=0.1.0 <1.0.0",
    "@prisma/client": "^5.0.0 || ^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-resilience": "workspace:^",
    "@prisma/client": "^6.19.3",
    "@testcontainers/postgresql": "^10.18.0",
    "prisma": "^6.19.3",
    "tsup": "^8",
    "typescript": "^5.9.3",
    "vitest": "^3"
  }
}
