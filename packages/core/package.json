  },
  "peerDependenciesMeta": {
    "@dudousxd/nestjs-diagnostics": {
      "optional": true
    },
    "@nestjs/event-emitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-diagnostics": "^0.2.3",
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/testing": "^11",
    "@types/node": "^22",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "tsup": "^8",
    "typescript": "^5.6",
    "vitest": "^3"
  }
