{
  "name": "@dudousxd/nestjs-resilience",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-diagnostics": ">=0.2.0 <1",
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11"
  },
  "peerDependenciesMeta": {
    "@dudousxd/nestjs-diagnostics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-diagnostics": "^0.2.3",
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/testing": "^11",
    "@tanstack/intent": "^0.3.2",
    "@types/node": "^22",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "tsup": "^8",
    "typescript": "^5.6",
    "vitest": "^3"
  },
  "keywords": [
    "tanstack-intent"
  ]
}
