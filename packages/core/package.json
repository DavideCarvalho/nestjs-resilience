    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-diagnostics": ">=0.2.0 <1",
    "@nestjs/common": "^10 || ^11",
